# ---- LLM (agnostico via init_chat_model) ----
# provider: anthropic | openai
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5
LLM_TEMPERATURE=0.2

# Claves segun el provider que uses:
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ---- Base de datos ----
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/blueprint
# DSN sincrono que usa el checkpointer de LangGraph (sin el +psycopg de SQLAlchemy):
LANGGRAPH_PG_DSN=postgresql://postgres:postgres@localhost:5432/blueprint

# ---- Auth ----
JWT_SECRET=change-me-in-prod-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- App ----
CORS_ORIGINS=http://localhost:3000
